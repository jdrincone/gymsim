# Cadena de conexión a Supabase.
# Usa el "Session pooler" (puerto 5432) y codifica en URL los caracteres especiales de la
# contraseña ($ -> %24, ? -> %3F, @ -> %40, etc.).
DATABASE_URL=postgresql://postgres.TU_PROYECTO:TU_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Aceleración del llenado autónomo (gymsim tick): 1 = ritmo real; 24 = 1 día por hora real.
SIM_ACCEL=24
